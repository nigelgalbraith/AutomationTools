      },
      "field_d": {
        "regex": "\"id\"\\s*:\\s*\"(\\d+)\""
      }
    },
    "download_urls": [
      "https://example.com/collection/a"
    ],
    "link_selector": "a[href*='/item/']",
    "links_per_search": 10,
    "download_delay": 3.0,
    "filename_from_url_regex": "/item/(\\d+)",
    "title_selectors": [
      "[data-automation='itemTitle']",
      "h1"
    ]
  },

